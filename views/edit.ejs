<%- include('header.ejs'); -%>
<div class="container" style="margin-top: 20px;">
    <h1>Edit Post</h1>
    <hr>
 <form action="/edit" method="POST" style="margin-top: 20px;width: 50%;display: flex;flex-direction: column;gap: 10px;">
    <input type="hidden" name="id" value="<%= post.id %>">
    <label for="editedtitle" style="color: aliceblue;font-weight: bold;">Title:</label>
    <input type="text" name="editedtitle" value="<%= post.title %>" required>
    <label for="editedpost" style="color: aliceblue;font-weight: bold;">Post:</label>
    <textarea name="editedpost" style="resize: none" required><%= post.post %></textarea>
    <button type="submit">Save Changes</button>
 </form>
</div>

